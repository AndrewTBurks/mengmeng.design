---
interface Props {}
const {} = Astro.props;
---

<footer class="site-footer">
  <p class="footer-copy">
    <span class="footer-muted">©</span> {new Date().getFullYear()} Mengmeng
  </p>
  <ul class="footer-links">
    <li><a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram (opens in new tab)">Instagram</a></li>
    <li><a href="https://are.na" target="_blank" rel="noopener" aria-label="Are.na (opens in new tab)">Are.na</a></li>
    <li><a href="mailto:Mengmeng%20Dong%3Chello@mengmeng.design%3E" aria-label="Send email">Email</a></li>
  </ul>
</footer>

<style>
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-lg) var(--gutter);
    border-top: 1px solid var(--color-neutral-border);
    font-size: var(--text-small);
  }

  .footer-copy {
    color: var(--color-neutral-muted);
  }

  .footer-muted {
    color: var(--color-neutral-muted);
    margin-right: 0.2em;
  }

  .footer-links {
    display: flex;
    gap: var(--space-md);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links a {
    color: var(--color-neutral-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }
</style>