---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base
  title={`${project.data.title} — Mengmeng`}
  description={project.data.description}
>
  <div class="page-project">
    <div class="project-header">
      <a href="/work" class="back-link">← Back to work</a>
      <div class="project-meta">
        <span class="project-category">{project.data.category}</span>
        <span class="project-year">{project.data.year}</span>
      </div>
    </div>

    <div class="project-hero">
      <img
        src={project.data.image}
        alt={project.data.title}
        class="project-image"
      />
    </div>

    <div class="project-body">
      <h1 class="project-title">{project.data.title}</h1>
      <div class="project-description">
        <p>{project.data.description}</p>
      </div>
      <div class="project-content">
        <Content />
      </div>
    </div>
  </div>
</Base>

<style>
  .page-project {
    min-height: calc(100dvh - var(--nav-height));
    padding: var(--space-2xl) var(--gutter) var(--space-4xl);
    max-width: 72ch;
    margin: 0 auto;
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3xl);
  }

  .back-link {
    font-size: var(--text-label);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-neutral-text);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-out-quart);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .project-meta {
    display: flex;
    gap: var(--space-md);
    font-size: var(--text-label);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .project-category {
    color: var(--color-primary);
  }

  .project-year {
    color: var(--color-neutral-muted);
  }

  .project-hero {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    margin-bottom: var(--space-3xl);
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-body {
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp var(--duration-slow) var(--ease-out-quart) forwards;
    animation-delay: 100ms;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-body {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  .project-title {
    font-size: var(--text-display);
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--color-neutral-text);
    margin-bottom: var(--space-xl);
  }

  .project-description {
    margin-bottom: var(--space-2xl);
  }

  .project-description p {
    font-size: var(--text-body);
    color: var(--color-neutral-muted);
    line-height: var(--leading-body);
  }

  .project-content {
    font-size: var(--text-body);
    color: var(--color-neutral-text);
    line-height: var(--leading-body);
  }

  .project-content p {
    margin-bottom: var(--space-lg);
  }

  .project-content p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .project-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }
  }
</style>