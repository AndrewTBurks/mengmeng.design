---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import ProjectImage from '../../components/ProjectImage.astro';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Work — Mengmeng"
  description="Selected projects by Mengmeng — illustration, motion, editorial, oil painting."
>
  <div class="page-work">
    <div class="timeline-viewport" aria-label="Project timeline">
      <div class="timeline-track">
        <div class="timeline">
          {projects.map((project, index) => (
        <article
          class={`timeline-row timeline-item ${index % 2 === 0 ? 'row-image-left' : 'row-image-right'}`}
          data-index={index}
        >
          {/* Year bubble — sits on the center line, in the letterbox */}
          <div class="row-bubble" aria-hidden="true">
            <span class="row-year">{project.data.year}</span>
          </div>

          {/* Row content: 16:9, full width, centered in the 100vh row */}
          <div class="row-content">
            <div class="row-image-wrap">
              <a href={`/work/${project.id}`} class="row-image-link" aria-label={`View ${project.data.title}`}>
                <ProjectImage
                  src={project.data.images[0].src}
                  alt={project.data.title}
                  class="row-image"
                />
              </a>
            </div>

            <div class="row-meta">
              <span class="row-category">{project.data.category}</span>
              <h2 class="row-title">{project.data.title}</h2>
              <p class="row-desc">{project.data.description}</p>
            </div>
          </div>
        </article>
        ))}
          <footer class="timeline-footer">
            <Footer />
          </footer>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  const track = document.querySelector('.timeline-track');
  if (track) {
    const rows = Array.from(track.querySelectorAll('.timeline-row')) as HTMLElement[];

    const setActive = (index: number) => {
      // First, remove clipped from all rows
      rows.forEach((row) => {
        row.classList.remove('is-clipped');
      });

      rows.forEach((row, i) => {
        if (i === index) {
          row.style.opacity = '1';
          row.classList.add('is-active');
          row.classList.remove('is-faded');
        } else {
          row.style.opacity = '0.10';
          row.classList.remove('is-active');
          row.classList.add('is-faded');
        }
      });

      // Mark clipped rows: a row is clipped when it's positioned at the
      // top or bottom edge of the timeline viewport — partially cut off by overflow.
      const viewportHeight = document.querySelector('.timeline-viewport')?.offsetHeight ?? window.innerHeight;
      const prev = rows[index - 1];
      const next = rows[index + 1];
      if (prev) {
        const prevBottom = prev.getBoundingClientRect().bottom;
        if (prevBottom < 0) prev.classList.add('is-clipped');
      }
      if (next) {
        const nextTop = next.getBoundingClientRect().top;
        if (nextTop > viewportHeight) next.classList.add('is-clipped');
      }
    };

    // Initial: first row active
    setActive(0);

    // Scroll-snap focal observer — row closest to viewport center wins
    const observer = new IntersectionObserver(
      () => {
        let best: { el: HTMLElement; dist: number } | null = null;
        rows.forEach((row) => {
          const rect = row.getBoundingClientRect();
          const center = rect.top + rect.height / 2;
          const vhCenter = window.innerHeight / 2;
          const dist = Math.abs(center - vhCenter);
          if (!best || dist < best.dist) best = { el: row, dist };
        });
        if (best) setActive(rows.indexOf(best.el));
      },
      { threshold: Array.from({ length: 21 }, (_, i) => i * 0.05) }
    );

    rows.forEach((row) => observer.observe(row));
  }
</script>

<style>
  /* ── Page Work — only .timeline scrolls, body/html handled globally ─── */
  .page-work {
    height: 100vh;
    width: 100%;
    overflow: hidden;
  }

  /* ── Timeline Viewport — full width, minus sticky header ── */
  .timeline-viewport {
    height: calc(100vh - 65px);
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Timeline Track — full width, holds the scroll ── */
  .timeline-track {
    position: relative;
    width: 100%;
    height: 100%;
    overflow-y: scroll;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }

  /* ── Timeline — constrained to 4:3, centered inside the full-width track ── */
  .timeline {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(100%, calc((100vh - 65px) * 4 / 3));
    height: 100%;
  }

  /* ── Timeline Row — cinemascope 2.39:1, snaps to center ─── */
  .timeline-row {
    position: relative;
    width: 100%;
    aspect-ratio: 2.39 / 1;
    scroll-snap-align: center;
    scroll-snap-stop: always;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Default: faded */
    opacity: 0.10;
    transition: opacity 0.4s var(--ease-out-quart);
    margin-block: 8px;
  }

  .timeline-row.is-active {
    opacity: 1;
  }

  /* Entrance animation on the row content */
  .timeline-item {
    opacity: 0;
    transform: scale(0.985);
    transition:
      opacity 0.45s var(--ease-out-quart),
      transform 0.45s var(--ease-out-quart);
  }

  .timeline-item.is-active {
    opacity: 1;
    transform: scale(1);
  }

  /* Clipped rows: top or bottom of viewport get 10% even if "active" during scroll */
  .timeline-row.is-clipped {
    opacity: 0.10 !important;
  }

  /* ── Timeline Footer ──────────────────────────────────────── */
.timeline-footer {
    width: 100%;
    flex-shrink: 0;
  }

  /* ── Row gap ─────────────────────────────────────────────── */
  .timeline-row {
    margin-block: 12px;
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-item,
    .timeline-row {
      opacity: 1 !important;
      transform: none;
      transition: none;
    }
  }

/* ── Row Content — 16:9 grid, full width of the row ─────── */
  .row-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-flow: dense;
    width: 100%;
    height: 100%;
  }

  /* ── Year Bubble — on the center line, in the letterbox ──── */
  .row-bubble {
    position: absolute;
    left: 50%;
    bottom: 16px;
    transform: translateX(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    background: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 4px var(--color-neutral-bg);
  }

  .row-year {
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.02em;
    color: oklch(97% 0.006 50);
    line-height: 1;
  }

  /* ── Image Side ─────────────────────────────────────────── */
  .row-image-left .row-image-wrap {
    grid-column: 1;
  }

  .row-image-right .row-image-wrap {
    grid-column: 2;
  }

  /* ── Meta Side ──────────────────────────────────────────── */
  .row-image-left .row-meta {
    grid-column: 2;
  }

  .row-image-right .row-meta {
    grid-column: 1;
  }

  /* ── Image ───────────────────────────────────────────────── */
  .row-image-wrap {
    position: relative;
    overflow: hidden;
    background: var(--color-neutral-surface);
    height: 100%;
  }

  .row-image-link {
    display: block;
    height: 100%;
    overflow: hidden;
  }

  .row-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    filter: blur(12px);
    transform: scale(1.04);
    transition:
      filter var(--duration-slow) var(--ease-out-quart),
      transform var(--duration-slow) var(--ease-out-quart);
  }

  .row-image-link:hover .row-image {
    filter: blur(4px);
    transform: scale(1.04);
  }

  .row-image-link:hover .row-image-soon {
    background: oklch(0% 0 0 / 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .row-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      oklch(0% 0 0 / 0.06) 100%
    );
    pointer-events: none;
  }

  .row-image-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
  }

  /* Coming soon overlay — always visible since images aren't final */
  .row-image-soon {
    display: flex !important;
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    background: oklch(0% 0 0 / 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    pointer-events: none;
  }

  .row-image-soon-text {
    font-size: var(--text-label);
    font-weight: var(--weight-medium);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: oklch(97% 0.006 50);
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid oklch(97% 0.006 50 / 0.4);
  }

  /* ── Meta ─────────────────────────────────────────────────── */
  .row-meta {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-2xs);
    padding: var(--space-2xl) var(--space-xl);
    background: var(--color-neutral-bg);
    height: 100%;
  }

  .row-category {
    font-size: var(--text-label);
    font-weight: var(--weight-medium);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }

  .row-title {
    font-size: clamp(var(--text-body), 2.5vw, var(--text-headline));
    font-weight: var(--weight-light);
    letter-spacing: -0.01em;
    color: var(--color-neutral-text);
    line-height: var(--leading-tight);
  }

  .row-desc {
    font-size: var(--text-small);
    color: var(--color-neutral-muted);
    line-height: var(--leading-body);
    margin-top: var(--space-sm);
    max-width: 36ch;
  }

  /* ── Responsive: single column below 1024px ─────────────── */
  @media (max-width: 1024px) {
    .page-work {
      height: auto;
      overflow: visible;
    }

    .timeline {
      height: auto;
      overflow: visible;
      scroll-snap-type: none;
    }

    .timeline-row {
      height: auto !important;
      aspect-ratio: auto !important;
      scroll-snap-align: none;
      scroll-snap-stop: normal;
      opacity: 1 !important;
      padding: var(--space-3xl) var(--gutter);
    }

    .timeline-row.is-faded {
      opacity: 0.10 !important;
    }

    .timeline-row.is-active {
      opacity: 1 !important;
    }

    .row-frame {
      height: auto;
      aspect-ratio: unset;
      border: none;
      position: static;
    }

    .row-content {
      position: static;
      aspect-ratio: unset;
      display: flex;
      flex-direction: column;
      width: 100%;
      height: auto;
    }

    .row-bubble {
      position: static;
      transform: none;
      width: 36px;
      height: 36px;
      margin-bottom: var(--space-sm);
    }

    .row-image-left .row-image-wrap,
    .row-image-right .row-image-wrap,
    .row-image-left .row-meta,
    .row-image-right .row-meta {
      grid-column: 1;
    }

    .row-image-wrap {
      width: 100% !important;
      height: auto !important;
      aspect-ratio: 16 / 9 !important;
      min-height: 0;
      flex-shrink: 0;
    }

    .row-image-link {
      display: block;
      width: 100% !important;
      height: auto !important;
    }

    .row-image {
      width: 100% !important;
      height: auto !important;
      aspect-ratio: 16 / 9 !important;
      object-fit: contain;
    }

    .row-image-soon {
      display: flex !important;
    }

    .row-meta {
      padding: var(--space-xl) 0;
      height: auto;
    }

    .timeline-item {
      opacity: 1;
      transform: none;
    }
  }
</style>